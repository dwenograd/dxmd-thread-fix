// version.rc - Windows VERSIONINFO resource for dxgi.dll.
//
// Embedded in the DLL so:
//   - Users can verify identity via right-click → Properties → Details.
//     ProductName should read "dxmd-thread-fix".
//   - Antivirus / Windows Defender heuristics can recognize the binary
//     as a named, versioned project rather than an anonymous unsigned
//     DLL. Reduces (but does not eliminate) false-positive rate.
//   - install.ps1 and uninstall.ps1 use the ProductName field as the
//     "is this our DLL?" identity check — robust across versions
//     (upgrade from v1.0 to v1.1 doesn't trigger the foreign-mod-
//     detected path, because the ProductName still matches).
//
// Update this file at every version bump:
//   - DTF_VERSION (the 4-int tuple)
//   - DTF_VERSION_STR (the human string)
// FileVersion and ProductVersion get the same value — there's no
// distinction worth making in a single-binary project like this.

#include <winver.h>

#define DTF_VERSION         1, 0, 0, 0
#define DTF_VERSION_STR     "1.0.0.0"
#define DTF_COMPANY         "dxmd-thread-fix"
#define DTF_PRODUCT         "dxmd-thread-fix"
#define DTF_DESC            "Thread-count crash fix for Deus Ex: Mankind Divided"
#define DTF_FILE_DESC       "DXGI proxy that hooks CPU-discovery APIs to fix DXMD's high-core-CPU crash"
#define DTF_INTERNAL_NAME   "dxgi.dll"
#define DTF_ORIGINAL_NAME   "dxgi.dll"
#define DTF_COPYRIGHT       "MIT licensed. See https://github.com/dwenograd/dxmd-thread-fix"
#define DTF_COMMENTS        "Not affiliated with Eidos, Square Enix, or Microsoft. Proxies the system dxgi.dll and installs MinHook detours on six CPU-topology APIs (plus optionally SetThreadAffinityMask when ClampAffinity=1 in dxmd-thread-fix.ini)."

VS_VERSION_INFO VERSIONINFO
    FILEVERSION     DTF_VERSION
    PRODUCTVERSION  DTF_VERSION
    FILEFLAGSMASK   VS_FFI_FILEFLAGSMASK
    FILEFLAGS       0
    FILEOS          VOS__WINDOWS32
    FILETYPE        VFT_DLL
    FILESUBTYPE     VFT2_UNKNOWN
BEGIN
    BLOCK "StringFileInfo"
    BEGIN
        BLOCK "040904B0"
        BEGIN
            VALUE "CompanyName",      DTF_COMPANY
            VALUE "FileDescription",  DTF_FILE_DESC
            VALUE "FileVersion",      DTF_VERSION_STR
            VALUE "InternalName",     DTF_INTERNAL_NAME
            VALUE "LegalCopyright",   DTF_COPYRIGHT
            VALUE "OriginalFilename", DTF_ORIGINAL_NAME
            VALUE "ProductName",      DTF_PRODUCT
            VALUE "ProductVersion",   DTF_VERSION_STR
            VALUE "Comments",         DTF_COMMENTS
        END
    END
    BLOCK "VarFileInfo"
    BEGIN
        VALUE "Translation", 0x0409, 0x04B0
    END
END
